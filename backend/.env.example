# ============================================
# Quikko - Variables d'environnement Backend
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# --- Base de données MongoDB ---
MONGO_URL=
DB_NAME=

# --- Authentification JWT ---
# Clé secrète pour signer les tokens JWT (générer avec: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=

# --- Compte administrateur (créé au démarrage) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Intégration IA (Claude Sonnet via Emergent) ---
# Clé universelle Emergent pour la génération de flashcards par IA
# Obtenir sur: Profil Emergent → Universal Key
EMERGENT_LLM_KEY=
